#
# Copy to .env and adjust. .env is git-ignored — never commit real secrets.
# Defaults boot a working localhost bench with no edits.

# ── ChirpStack ───────────────────────────────────────────────────────────────
# Signs ChirpStack login + API tokens. CHANGE THIS for anything beyond a private
# bench. Generate one with: openssl rand -base64 32
CHIRPSTACK_API_SECRET=change-me-please

# Bootstrap admin login the provisioner uses (ChirpStack v4 default is admin/admin).
CHIRPSTACK_ADMIN_EMAIL=admin
CHIRPSTACK_ADMIN_PASSWORD=admin

# Host ports. Change these to run alongside an existing ChirpStack/Mosquitto on
# the same host (e.g. a separate chirpstack-docker stack). Internal service-to-
# service traffic uses the compose network and is unaffected — but if you remap
# the MQTT/REST host ports, also update LEFTENANT_CHIRPSTACK_URL / LEFTENANT_MQTT_URL
# below to match (the browser uses those).
CHIRPSTACK_HOST_PORT=8080          # admin UI + gRPC
CHIRPSTACK_REST_HOST_PORT=8090     # REST API (Leftenant calls this)
GATEWAY_BRIDGE_UDP_PORT=1700       # Semtech UDP packet forwarder (physical gateways)
MOSQUITTO_MQTT_PORT=1883           # native MQTT
MOSQUITTO_WS_PORT=9001             # MQTT over websockets (browser join monitor)

# ── Tenant / API key created by the provisioner ──────────────────────────────
TENANT_NAME=Intelligent Farming
API_KEY_NAME=intelligent-farming-stack

# Optional ChirpStack JS payload codecs the provisioner best-effort attaches to
# device profiles. Defaults to this repo's ./codecs (drop *.js there). Point it at
# another folder — e.g. ../intelligent-farming-hub/codecs — to reuse a codec set
# from elsewhere. Empty/missing dir = no-op.
CODECS_DIR=./codecs

# ── Leftenant ────────────────────────────────────────────────────────────────
# Host port Leftenant is served on.
LEFTENANT_HOST_PORT=4173
# Browser origin Leftenant is reached at — MUST match LEFTENANT_HOST_PORT and the
# host. Used as the ChirpStack REST CORS allow-origin. For LAN access change all
# three of these to the device's address, e.g. http://192.168.1.50:4173 etc.
LEFTENANT_ORIGIN=http://localhost:4173
# URLs baked into Leftenant's runtime config.json (how the BROWSER reaches
# ChirpStack — not the compose network). Change the host for LAN access.
LEFTENANT_CHIRPSTACK_URL=http://localhost:8090
LEFTENANT_MQTT_URL=ws://localhost:9001

# ── Device-event store (ChirpStack PostgreSQL integration) ────────────────────
# Standalone Postgres that ChirpStack writes every device event into (it auto-
# creates the event_* tables). events-api serves read-only GraphQL/GraphiQL over it.
EVENTS_POSTGRES_USER=events         # DB owner; ChirpStack connects as this and creates the tables
EVENTS_POSTGRES_PASSWORD=changeme
EVENTS_POSTGRES_DB=chirpstack_events
EVENTS_POSTGRES_API_USER=events_api # read-only role PostGraphile connects as
EVENTS_POSTGRES_API_PASSWORD=changeme-api
EVENTS_POSTGRES_HOST_PORT=5434      # host-side psql / export
EVENTS_POSTGRES_HOST_BIND=127.0.0.1 # set 0.0.0.0 (or a LAN/VPN IP) to expose Postgres for Fivetran (TLS + firewall first!)
EVENTS_API_HOST_PORT=5050           # GraphQL endpoint (5000 is taken by macOS AirPlay Receiver)
EVENTS_API_HOST_BIND=127.0.0.1      # set 0.0.0.0 to expose on the LAN (TLS first!)
EVENTS_API_GRAPHIQL=true

# ── Fivetran / log-based CDC on events-postgres (opt-in) ──────────────────────
# See README "Fivetran / off-device sync". All disabled by default.
# 1) wal_level=logical enables the write-ahead log Fivetran's log-based
#    connector reads. Leave `replica` unless you're syncing off-device.
EVENTS_POSTGRES_WAL_LEVEL=replica   # set `logical` for Fivetran log-based CDC, then recreate events-postgres
EVENTS_POSTGRES_MAX_WAL_SENDERS=10  # PG16 default; one Fivetran slot fits
EVENTS_POSTGRES_MAX_REPLICATION_SLOTS=10
# 2) Dedicated read-only replication role. Set BOTH to have events-initdb's
#    010_events_roles.sh create the role + publication. Leaving either blank
#    skips it. Example user: fivetran. Generate a password: openssl rand -base64 24
#    (Keep these two on their own lines with no trailing comment — an empty value
#    followed by an inline # comment is parsed as the value by docker compose.)
EVENTS_POSTGRES_FIVETRAN_USER=
EVENTS_POSTGRES_FIVETRAN_PASSWORD=
EVENTS_POSTGRES_FIVETRAN_PUBLICATION=fivetran_pub
